# Voice Live spike — env vars (NÃO commitar .env real).
#
# Os 2 primeiros são obrigatórios. O resto tem defaults razoáveis dentro
# do main.go (ver loadConfig).

# URL completa do recurso Azure Foundry. Pode terminar com / ou não.
VOICE_LIVE_ENDPOINT=https://td-foundry-voiceflow-rsc-eus2.cognitiveservices.azure.com

# Chave da API. Buscar do Key Vault em vez de digitar:
#   $env:VOICE_LIVE_KEY = az keyvault secret show --vault-name danieldev --name TpVoiceLiveApi --query value -o tsv
VOICE_LIVE_KEY=

# Modelo: o nome literal aceito pelo query param ?model=...
# Opções conhecidas que funcionam no resource td-foundry-voiceflow-rsc-eus2
# (validadas pela POC interna):
#   gpt-realtime-mini             — Voice Live BASIC, native realtime, menor latência (recomendado pro spike)
#   gpt-realtime-mini-2025-12-15  — versão pinada (mesma família)
#   gpt-realtime                  — Voice Live PRO, native realtime, mais caro
#   gpt-4o-mini                   — modelo híbrido (STT separado + LLM + TTS), mais barato
VOICE_LIVE_MODEL=gpt-realtime-mini

# Voz Azure neural. Opções recomendadas pra PT-BR:
#   pt-BR-Thalita:DragonHDLatestNeural  — HD feminina (recomendado, qualidade superior, default)
#   pt-BR-Macerio:DragonHDLatestNeural  — HD masculino
#   pt-BR-FranciscaNeural               — standard feminina (calm style)
#   pt-BR-AntonioNeural                 — standard masculino
#   pt-BR-ThalitaMultilingualNeural     — standard multilingual feminina
#   pt-BR-MacerioMultilingualNeural     — standard multilingual masculino
# Lista completa: https://learn.microsoft.com/azure/ai-services/speech-service/language-support?tabs=tts
VOICE_LIVE_VOICE=pt-BR-Thalita:DragonHDLatestNeural

# System prompt do agente.
VOICE_LIVE_INSTRUCTIONS=Você é um atendente de call center educado e objetivo.

# Idioma para o VAD semântico multilingual.
VOICE_LIVE_LANGUAGE=pt-BR
