# AI Gateway — environment variables template.
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Homologação: danie-mc4ryviy-westeurope (West Europe)
# Azure Portal → AI Foundry resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://danie-mc4ryviy-westeurope.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# ── Azure Content Safety (optional — required for Tier 3) ─────────────────────
# Uncomment azure_content_safety block in gateway.yaml to activate.
# Azure Portal → Content Safety resource → Keys and Endpoint
# AZURE_CS_ENDPOINT=https://YOUR-CS-RESOURCE.cognitiveservices.azure.com
# AZURE_CS_API_KEY=your-azure-content-safety-api-key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DATABASE_URL=postgres://gateway:gateway@localhost:5432/gateway?sslmode=disable

# AES-256-GCM key for encrypting proxy target credentials at rest (ADR-0012).
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=your-64-char-hex-key-here

# ── Optional overrides ────────────────────────────────────────────────────────
# CONFIG_PATH: path to gateway.yaml (default: configs/gateway.yaml)
# CONFIG_PATH=configs/gateway.yaml

# PROVIDER: "azure" (default) or "mock" (no Azure credentials needed for dev)
# PROVIDER=mock

# ── Azure Key Vault (optional — ADR-0018) ─────────────────────────────────────
# Quando setado, o gateway resolve ${kv:NAME} no gateway.yaml lendo do KV.
# Autenticação: DefaultAzureCredential (em dev usa `az login`; em prod usa
# Managed Identity automaticamente).
# Veja docs/keyvault-setup.md para o passo a passo.
# KEYVAULT_URI=https://danieldev.vault.azure.net/
